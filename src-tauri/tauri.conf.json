{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "faster-whisper-frontend",
  "version": "0.1.12",
  "identifier": "ch.informethic.faster-whisper-frontend",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "faster-whisper-frontend",
        "width": 1040,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "visible": true
      },
      {
        "label": "overlay",
        "title": "dictation",
        "width": 820,
        "height": 132,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "focus": false,
        "shadow": false,
        "visible": false
      },
      {
        "label": "quickadd",
        "title": "Quick add",
        "width": 600,
        "height": 480,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "focus": true,
        "shadow": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'",
      "devCsp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "msi", "nsis"],
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper", "silent": true },
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "linux": {
      "deb": {
        "depends": ["libasound2", "libxkbcommon0"]
      }
    },
    "category": "Utility",
    "shortDescription": "Dictation client for a self-hosted faster-whisper server",
    "longDescription": "A FOSS cross-platform (Windows + Linux) push-to-talk and hands-free dictation client that streams microphone audio to a self-hosted faster-whisper / OpenAI-compatible transcription server and types the result into the focused field of any application.",
    "homepage": "https://github.com/v3DJG6GL/faster-whisper-frontend",
    "publisher": "faster-whisper-frontend contributors",
    "license": "AGPL-3.0-or-later",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
